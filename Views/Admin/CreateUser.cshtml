@model IntranetDocumentos.Models.ViewModels.CreateUserViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CreateUser"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3>
                    <i class="bi bi-person-plus"></i> @Localizer["CreateUser"]
                </h3>
            </div>
            <div class="card-body">
                <form asp-action="CreateUser" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                <input asp-for="Email" class="form-control" placeholder="@Localizer["EmailPlaceholder"]" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="UserName" class="form-label">@Localizer["UserNameOptional"]</label>
                                <input asp-for="UserName" class="form-control" placeholder="@Localizer["UserNamePlaceholder"]" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                                <input asp-for="Password" class="form-control" type="password" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                                <div class="form-text">@Localizer["PasswordRequirements"]</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmPassword"]</label>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="DepartmentId" class="form-label">@Localizer["Department"]</label>
                                <select asp-for="DepartmentId" class="form-select">
                                    <option value="">@Localizer["SelectDepartment"]</option>
                                    @foreach (var department in Model.AvailableDepartments)
                                    {
                                        <option value="@department.Id">@department.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Role" class="form-label">@Localizer["Function"]</label>
                                <select asp-for="Role" class="form-select">
                                    <option value="">@Localizer["SelectFunction"]</option>
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="Role" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-info">
                        <h6><i class="bi bi-info-circle"></i> @Localizer["RoleInformation"]:</h6>
                        <ul class="mb-0">
                            <li><strong>Admin:</strong> @Localizer["AdminRoleDescription"]</li>
                            <li><strong>Gestor:</strong> @Localizer["ManagerRoleDescription"]</li>
                            <li><strong>Usuario:</strong> @Localizer["UserRoleDescription"]</li>
                        </ul>
                    </div>
                    
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> @Localizer["Common.Back"]
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-person-plus"></i> @Localizer["CreateUser"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
